package homepage

import (
	"fmt"
	"sylvie/internal/http/views/components"
	"sylvie/internal/http/views/layouts"
)

type Video struct {
	ID            string `json:"id"`
	Title         string `json:"title"`
	ThumbnailPath string `json:"thumbnail_path"`
}

type HomepageViewModel struct {
	Videos []Video `json:"videos"`
}

templ HomePage(viewmodel HomepageViewModel) {
	@layouts.Root() {
		<div>
			@components.Header()
			<main class="main homepage">
				<div class="videos-container">
					for _,video := range viewmodel.Videos {
						<a
							href={ fmt.Sprintf("/watch?video=%s", video.ID) }
							class="video"
						>
							<img
								src={video.ThumbnailPath}
								alt="video thumbnail"
								class="thumbnail"
							/>
							<p class="title">{ video.Title }</p>
						</a>
					}
				</div>
			</main>
		</div>
	}
}
